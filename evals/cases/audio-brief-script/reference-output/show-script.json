      "turns": [
        {
          "speaker": "host_a",
          "text": "Welcome back. I'm Mira, and Theo is here with me for a quick look at how an audio brief becomes a show instead of a read-aloud note.",
          "synthesis_unit_ids": [
            "story-setup-and-host-dynamic"
          ],
          "evidence_ids": [
            "item_story_setup"
          ],
          "pacing": "warm and direct",
          "emotion": "focused",
          "transition": "show welcome"
        },
        {
          "speaker": "host_b",
          "text": "Good to be here. The question is simple: before anyone presses render, what has to be true on the page?",
          "synthesis_unit_ids": [
            "story-setup-and-host-dynamic"
          ],
          "evidence_ids": [
            "item_two_hosts"
          ],
          "pacing": "conversational",
          "emotion": "curious",
          "transition": "listener question"
        }
