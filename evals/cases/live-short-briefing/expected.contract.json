{
  "schema_version": "1",
  "hard_gates": {
    "required_files": [
      "feed-items.snapshot.json",
      "briefing.synthesis.json",
      "synthesis-review.json",
      "command-trace.json"
    ],
    "schema_validations": [
      {
        "file": "briefing.synthesis.json",
        "schema": "structured-synthesis"
      }
    ],
    "review_verdicts": [
      {
        "file": "synthesis-review.json",
        "verdict": "ready"
      }
    ],
    "command_order": ["version", "auth status", "item list", "item get", "synthesis validate"],
    "json_path_checks": [
      {
        "file": "feed-items.snapshot.json",
        "path": "$.workflow",
        "expected": "briefing_from_recent_items"
      },
      {
        "file": "feed-items.snapshot.json",
        "path": "$.items",
        "expected": { "min_length": 1 }
      },
      {
        "file": "briefing.synthesis.json",
        "path": "$.scope.request",
        "expected": { "includes": "输出我的简报" }
      },
      {
        "file": "briefing.synthesis.json",
        "path": "$.units",
        "expected": { "min_length": 1 }
      },
      {
        "file": "synthesis-review.json",
        "path": "$.ready_for_artifact",
        "expected": true
      }
    ],
    "forbidden_patterns": ["access_token|refresh_token|password|auth login|auth anonymous|auth logout|--confirm|洞见一|不是.*而是"],
    "artifact_boundaries": ["no_skill_repo_writes", "only_case_output_writes"]
  }
}
