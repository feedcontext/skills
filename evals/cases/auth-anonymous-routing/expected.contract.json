{
  "schema_version": "1",
  "hard_gates": {
    "required_files": ["auth-plan.json", "command-trace.json"],
    "json_path_checks": [
      {
        "file": "auth-plan.json",
        "path": "$.workflow",
        "expected": "auth-anonymous-routing"
      },
      {
        "file": "auth-plan.json",
        "path": "$.uses_anonymous_by_default",
        "expected": true
      },
      {
        "file": "auth-plan.json",
        "path": "$.prompts_for_formal_login_by_default",
        "expected": false
      },
      {
        "file": "auth-plan.json",
        "path": "$.home_override_allowed",
        "expected": false
      }
    ],
    "forbidden_patterns": [
      {
        "file": "auth-plan.json",
        "pattern": "auth login.*default|override HOME|password"
      }
    ],
    "artifact_boundaries": [
      "no_skill_repo_writes",
      "only_case_output_writes",
      "no_live_api_without_permission"
    ]
  }
}
