{
  "schema_version": "1",
  "hard_gates": {
    "required_files": [
      "composition-request.json",
      "command-trace.json"
    ],
    "command_order": [
      "version",
      "auth status",
      "artifact compose"
    ],
    "json_path_checks": [
      {
        "file": "composition-request.json",
        "path": "$.artifact_type",
        "expected": "briefing_page"
      },
      {
        "file": "composition-request.json",
        "path": "$.user_request",
        "expected": {
          "includes": "local self-verification"
        }
      },
      {
        "file": "composition-request.json",
        "path": "$.scope.item_ids",
        "expected": {
          "min_length": 1
        }
      }
    ],
    "forbidden_patterns": [
      "洞见一",
      "不是.*而是",
      "synthesis validate",
      "show-script validate",
      "sizing validate"
    ],
    "artifact_boundaries": [
      "no_skill_repo_writes",
      "only_case_output_writes",
      "no_live_api_without_permission",
      "no_audio_provider_without_permission"
    ]
  }
}
