{
  "schema_version": "1",
  "hard_gates": {
    "required_files": [
      "briefing.synthesis.json",
      "synthesis-review.json",
      "command-trace.json"
    ],
    "schema_validations": [
      {
        "file": "briefing.synthesis.json",
        "schema": "structured-synthesis"
      }
    ],
    "review_verdicts": [
      {
        "file": "synthesis-review.json",
        "verdict": "ready"
      }
    ],
    "command_order": [
      "version",
      "synthesis validate"
    ],
    "json_path_checks": [
      {
        "file": "briefing.synthesis.json",
        "path": "$.scope.request",
        "expected": {
          "includes": "local self-verification"
        }
      },
      {
        "file": "synthesis-review.json",
        "path": "$.ready_for_artifact",
        "expected": true
      }
    ],
    "forbidden_patterns": [
      "洞见一",
      "不是.*而是"
    ],
    "artifact_boundaries": [
      "no_skill_repo_writes",
      "only_case_output_writes",
      "no_live_api_without_permission",
      "no_audio_provider_without_permission"
    ]
  }
}
