{
  "schema_version": "1",
  "hard_gates": {
    "required_files": ["feed-items-plan.json", "command-trace.json"],
    "json_path_checks": [
      {
        "file": "feed-items-plan.json",
        "path": "$.workflow",
        "expected": "feed-items-workflow"
      },
      {
        "file": "feed-items-plan.json",
        "path": "$.uses_item_list_all_for_all_matching",
        "expected": true
      },
      {
        "file": "feed-items-plan.json",
        "path": "$.list_returns_content",
        "expected": false
      },
      {
        "file": "feed-items-plan.json",
        "path": "$.uses_get_many_after_selection",
        "expected": true
      }
    ],
    "forbidden_patterns": [
      {
        "file": "feed-items-plan.json",
        "pattern": "item list.*content_text|search-content.*default"
      }
    ],
    "artifact_boundaries": [
      "no_skill_repo_writes",
      "only_case_output_writes",
      "no_live_api_without_permission"
    ]
  }
}
