{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://feedcontext.io/schemas/structured-synthesis.schema.json",
  "title": "FeedContext Structured Synthesis",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "scope", "units"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1"
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["request", "selection_rule"],
      "properties": {
        "request": {
          "type": "string",
          "minLength": 1
        },
        "time_range": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "published_after": {
              "type": "integer"
            },
            "published_before": {
              "type": "integer"
            },
            "label": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "candidate_count": {
          "type": "integer",
          "minimum": 0
        },
        "active_subscription_count": {
          "type": "integer",
          "minimum": 0
        },
        "selection_rule": {
          "type": "string",
          "minLength": 1
        },
        "used_contextual_evidence": {
          "type": "boolean"
        }
      }
    },
    "units": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/unit"
      }
    },
    "secondary_items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/secondary_item"
      }
    }
  },
  "$defs": {
    "unit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "title",
        "claim",
        "supporting_evidence",
        "selection_rationale",
        "rendering_priority"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": ["insight", "item_roundup", "briefing_section"]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "claim": {
          "type": "string",
          "minLength": 1
        },
        "supporting_evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/evidence"
          }
        },
        "selection_rationale": {
          "type": "string",
          "minLength": 1
        },
        "rendering_priority": {
          "type": "string",
          "enum": ["lead", "main", "secondary", "collapsed"]
        }
      }
    },
    "evidence": {
      "oneOf": [
        {
          "$ref": "#/$defs/feed_item_evidence"
        },
        {
          "$ref": "#/$defs/contextual_evidence"
        },
        {
          "$ref": "#/$defs/external_url_evidence"
        }
      ]
    },
    "feed_item_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "feed_item_id",
        "url",
        "subscription_title",
        "title",
        "relevance",
        "reason"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "const": "feed_item"
        },
        "feed_item_id": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "subscription_title": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "published_at": {
          "type": ["integer", "null"]
        },
        "relevance": {
          "type": "string",
          "enum": ["direct", "supporting", "background"]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "contextual_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "label", "relevance", "reason"],
      "properties": {
        "kind": {
          "type": "string",
          "const": "contextual"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "relevance": {
          "type": "string",
          "enum": ["direct", "supporting", "background"]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "external_url_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "url", "title", "relevance", "reason"],
      "properties": {
        "kind": {
          "type": "string",
          "const": "external_url"
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "relevance": {
          "type": "string",
          "enum": ["direct", "supporting", "background"]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "secondary_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["feed_item_id", "url", "title", "subscription_title", "group", "reason"],
      "properties": {
        "feed_item_id": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "subscription_title": {
          "type": "string",
          "minLength": 1
        },
        "published_at": {
          "type": ["integer", "null"]
        },
        "group": {
          "type": "string",
          "enum": ["supplemental", "low_information_gain", "out_of_scope"]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
